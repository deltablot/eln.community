  nginx:
    image: nginx:latest
    container_name: nginx-eln
    restart: always
    ports:
      - "127.0.0.1:8081:8081"
    extra_hosts:
      - 'host.docker.internal:host-gateway'
    volumes:
      - ./nginx/nginx.conf:/etc/nginx/nginx.conf:ro
      - ./nginx/certs:/etc/nginx/certs:ro
    networks:
      - eln
