# deploy eln.community service
# use: "docker compose up -d" to start service

networks:
  eln:

services:
  postgres:
    image: postgres:16-alpine
    container_name: eln-postgres-dev
    restart: always
    environment:
      - POSTGRES_DB=eln
      - POSTGRES_USER=eln
      - POSTGRES_PASSWORD=eln
    volumes:
      - ./data/postgres:/var/lib/postgresql/data
    networks:
      - eln
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U eln -d eln"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s

